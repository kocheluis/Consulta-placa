# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# Turborepo
.turbo/

# Environment
.env
.env.local
.env.*.local

# Prisma
packages/db/prisma/*.db

# Testing / coverage
coverage/
playwright-report/
test-results/

# Python cache (from skills tooling)
__pycache__/
*.py[cod]

# Artefactos de sondeo de scrapers (HTML/capturas)
**/__captured__/

# Datos de idioma de tesseract OCR (se descargan en runtime) + perfiles de navegador stealth
*.traineddata
.pw-profile/
.stealth-profile/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
tmp-design-handoff/

# Perfiles de Chrome para CDP (Turnstile pasivo, IP residencial) - datos locales
.cdp-*/
# Salidas/validacion local del scraping (screenshots, OCR, reportes, boletas)
validacion-fuentes/
# Base de datos local SQLite (PlacaPe) + boletas guardadas
data/
# Copia local de boletas descargadas del VPS (552MB de PDFs) + su análisis
boletas/
# Documentos de referencia sueltos (PDF/Word) y locks de Office — no son código
/*.pdf
/*.docx
~$*.docx
*.db
*.db-shm
*.db-wal
*.sqlite
