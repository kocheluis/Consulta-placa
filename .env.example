# Base de datos y caché
DATABASE_URL=postgresql://app:app@localhost:5432/placas
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_SCRAPING_PER_MINUTE=3

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Servicio de resolución de CAPTCHA (solo para scraping real; en tests se mockea)
CAPTCHA_PROVIDER=capsolver
CAPTCHA_API_KEY=

# TTL de caché / retención (cumplimiento legal)
REPORT_TTL_REGISTRAL_DAYS=7
REPORT_TTL_SEGUROS_HOURS=24
REPORT_TTL_SINIESTRALIDAD_HOURS=24
OWNER_RETENTION_DAYS=7

# Worker
WORKER_CONCURRENCY=2
SCRAPER_TIMEOUT_MS=30000
