# Base de datos y caché
DATABASE_URL=postgresql://app:app@localhost:5432/placas
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_SCRAPING_PER_MINUTE=3
RATE_LIMIT_AUTH_PER_MINUTE=5

# OBLIGATORIO en producción (mín. 16 caracteres). La API se niega a arrancar sin él.
# Genera uno aleatorio, p. ej.: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# CORS: dominios del frontend permitidos (coma-separados). Obligatorio en producción.
# Ej.: https://consulta-placa-web.vercel.app
WEB_ORIGIN=

# Supabase (Auth + Postgres para cuentas de usuario).
# Si ambas están presentes, la web usa Supabase Auth; si faltan, cae al
# backend de prueba (API Fastify). Cópialas desde:
#   Supabase → Project Settings → API → Project URL y anon/public key.
# Configúralas también en Vercel (Project → Settings → Environment Variables).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role (SOLO server-side: webhooks/checkout). NUNCA NEXT_PUBLIC_,
# nunca en el cliente. Salta el RLS. Copiar la "secret key" (sb_secret_...).
SUPABASE_SERVICE_ROLE_KEY=

# Pasarela IziPay (pago por reporte). Si faltan, los pagos operan en modo mock
# (aprobación inmediata para pruebas). Datos desde el back-office de IziPay/Lyra.
IZIPAY_SHOP_ID=
IZIPAY_SECRET_KEY=

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
# Habilita el reporte automático PRO (requiere API + worker desplegados).
# Déjalo vacío/false para un despliegue gratis solo con la consulta guiada.
NEXT_PUBLIC_PRO_ENABLED=true

# Resolución de CAPTCHA (solo para scraping real; en tests se mockea).
#  - local      → OCR gratuito (Tesseract.js). Resuelve la imagen de SUNARP. NO resuelve
#                 reCAPTCHA v2 de SBS (esa sección quedará "no disponible"). Sin clave.
#  - capsolver  → de pago. Resuelve imagen (SUNARP) y reCAPTCHA v2 (SBS). Requiere CAPTCHA_API_KEY.
#  - 2captcha   → de pago. Igual que capsolver.
CAPTCHA_PROVIDER=local
CAPTCHA_API_KEY=

# TTL de caché / retención (cumplimiento legal)
REPORT_TTL_REGISTRAL_DAYS=7
REPORT_TTL_SEGUROS_HOURS=24
REPORT_TTL_SINIESTRALIDAD_HOURS=24
OWNER_RETENTION_DAYS=7

# Worker
WORKER_CONCURRENCY=2
SCRAPER_TIMEOUT_MS=30000
